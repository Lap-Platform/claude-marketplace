@endpoints 16
@toc catalog(16)

@endpoint GET /catalog/datasets
@optional {select: str, where: str, order_by: str, limit: int=10, offset: int=0, refine: str, exclude: str, lang: str(en/fr/nl/pt/it/ar/de/es/ca/eu/sv), timezone: str=UTC}
