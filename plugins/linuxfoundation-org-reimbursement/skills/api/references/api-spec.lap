@lap v0.3
# Machine-readable API spec. Each @endpoint block is one API call.
@api Reimbursements API
@version 1.0
@auth ApiKey X-API-Key in header
@endpoints 7
@toc api-docs(1), expense(1), health(1), reimbursement(2), reset(1), tag(1)

@group api-docs
@endpoint GET /api-docs
@returns(200)

@endgroup

@group expense
@endpoint POST /expense/{action}/{reportId}
@required {action: any, reportId: any}
@returns(200)
@errors {400, 401, 500}

@endgroup

@group health
@endpoint GET /health
@returns(200)
@errors {503}

@endgroup

@group reimbursement
@endpoint POST /reimbursement/{projectId}
@required {body: any}
@returns(200)
@errors {400, 401, 500}

@endpoint PATCH /reimbursement/{projectId}
@required {body: map}
@returns(200)
@errors {400, 401, 404, 500}

@endgroup

@group reset
@endpoint POST /reset
@required {body: map}
@returns(200)
@errors {400, 401, 500}

@endgroup

@group tag
@endpoint POST /tag
@required {body: map}
@returns(200)
@errors {400, 401, 500}

@endgroup

@end
