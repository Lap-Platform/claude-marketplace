@lap v0.3
# Machine-readable API spec. Each @endpoint block is one API call.
@api Amazon SimpleDB
@version 2009-04-15
@endpoints 10
@toc root(10)

@endpoint POST /
@required {DomainName: str, Items: [DeletableItem]}

@endpoint POST /
@required {DomainName: str, Items: [ReplaceableItem]}
@errors {500:DuplicateItemName, 500:InvalidParameterValue, 500:MissingParameter, 500:NoSuchDomain, 500:NumberItemAttributesExceeded, 500:NumberDomainAttributesExceeded, 500:NumberDomainBytesExceeded, 500:NumberSubmittedItemsExceeded, 500:NumberSubmittedAttributesExceeded}

@endpoint POST /
@required {DomainName: str}
@errors {500:InvalidParameterValue, 500:MissingParameter, 500:NumberDomainsExceeded}

@endpoint POST /
@required {DomainName: str, ItemName: str}
@optional {Attributes: [DeletableAttribute], Expected: UpdateCondition}
@errors {500:InvalidParameterValue, 500:MissingParameter, 500:NoSuchDomain, 500:AttributeDoesNotExist}

@endpoint POST /
@required {DomainName: str}
@errors {500:MissingParameter}

@endpoint POST /
@required {DomainName: str}
@returns(200) {ItemCount: int?, ItemNamesSizeBytes: int(i64)?, AttributeNameCount: int?, AttributeNamesSizeBytes: int(i64)?, AttributeValueCount: int?, AttributeValuesSizeBytes: int(i64)?, Timestamp: int?}
@errors {500:MissingParameter, 500:NoSuchDomain}

@endpoint POST /
@required {DomainName: str, ItemName: str}
@optional {AttributeNames: [str], ConsistentRead: bool}
@returns(200) {Attributes: [Attribute]?}
@errors {500:InvalidParameterValue, 500:MissingParameter, 500:NoSuchDomain}

@endpoint POST /
@optional {MaxNumberOfDomains: int, NextToken: str}
@returns(200) {DomainNames: [str]?, NextToken: str?}
@errors {500:InvalidParameterValue, 500:InvalidNextToken}

@endpoint POST /
@required {DomainName: str, ItemName: str, Attributes: [ReplaceableAttribute]}
@optional {Expected: UpdateCondition}
@errors {500:InvalidParameterValue, 500:MissingParameter, 500:NoSuchDomain, 500:NumberDomainAttributesExceeded, 500:NumberDomainBytesExceeded, 500:NumberItemAttributesExceeded, 500:AttributeDoesNotExist}

@endpoint POST /
@required {SelectExpression: str}
@optional {NextToken: str, ConsistentRead: bool}
@returns(200) {Items: [Item]?, NextToken: str?}
@errors {500:InvalidParameterValue, 500:InvalidNextToken, 500:InvalidNumberPredicates, 500:InvalidNumberValueTests, 500:InvalidQueryExpression, 500:MissingParameter, 500:NoSuchDomain, 500:RequestTimeout, 500:TooManyRequestedAttributes}

@end
