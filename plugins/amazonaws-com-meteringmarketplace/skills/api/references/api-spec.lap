@version 2016-01-14
@auth AWS SigV4
@endpoints 4
@toc root(4)

@endpoint POST /
@required {UsageRecords: [UsageRecord], ProductCode: str}
@returns(200) {Results: [UsageRecordResult]?, UnprocessedRecords: [UsageRecord]?}

@endpoint POST /
