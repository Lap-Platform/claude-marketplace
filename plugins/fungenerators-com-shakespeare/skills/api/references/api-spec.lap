@lap v0.3
# Machine-readable API spec. Each @endpoint block is one API call.
@api Shakespeare API
@base http://api.fungenerators.com
@version 1.5
@auth ApiKey X-Fungenerators-Api-Secret in header
@endpoints 5
@toc shakespeare(5)

@endpoint GET /shakespeare/generate/name
@optional {variation: str(string), limit: int(integer)}
@returns(200)
@errors {401}

@endpoint GET /shakespeare/generate/insult
@optional {limit: int(integer)}
@returns(200)
@errors {401}

@endpoint GET /shakespeare/generate/lorem-ipsum
@optional {type: str(string), limit: int(integer)}
@returns(200)
@errors {401}

@endpoint GET /shakespeare/translate
@required {text: str(string)}
@returns(200)
@errors {401}

@endpoint GET /shakespeare/quote
@returns(200)
@errors {401}

@end
