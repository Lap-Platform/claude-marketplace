@optional {token: str, items: [map{enabled!: bool, expiresOn: str(date-time), adjustments: [map{symbol!: str, ask: num(double), bid: num(double), askAdjustment: num(double), bidAdjustment: num(double), previousClose: num(double)}]}]}
