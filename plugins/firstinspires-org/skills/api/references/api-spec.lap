@lap v0.3
# Machine-readable API spec. Each @endpoint block is one API call.
@api FRC Events
@base https://frc-api.firstinspires.org/v3.0
@auth Basic username:password
@endpoints 19
@toc root(1), {season}(18)

@group root
@endpoint GET /
@returns(200) {currentSeason: int, maxSeason: int, name: str, apiVersion: str, status: str}
@errors {500}

@endgroup

@group {season}
@endpoint GET /{season}
@auth Basic username:password
@optional {If-Modified-Since: str}
@returns(200) {eventCount: int, gameName: str, kickoff: str, rookieStart: int, teamCount: int, frcChampionships: [map]}
@errors {500}

@endpoint GET /{season}/events
@auth Basic username:password
@optional {If-Modified-Since: str}
@returns(200) {Events: [map], eventCount: int}
@errors {500}

@endpoint GET /{season}/districts
@auth Basic username:password
@optional {If-Modified-Since: str}
@returns(200) {districts: [map], districtCount: int}
@errors {500}

@endpoint GET /{season}/teams
@auth Basic username:password
@optional {If-Modified-Since: str}
@returns(200) {teams: [map], teamCountTotal: int, teamCountPage: int, pageCurrent: int, pageTotal: int}
@errors {500}

@endpoint GET /{season}/avatars
@auth Basic username:password
@optional {If-Modified-Since: str}
@returns(200) {teams: [map], teamCountTotal: int, teamCountPage: int, pageCurrent: int, pageTotal: int}
@errors {500}

@endpoint GET /{season}/awards/event/{eventCode}
@auth Basic username:password
@optional {If-Modified-Since: str}
@returns(200) {Awards: [map]}
@errors {500}

@endpoint GET /{season}/awards/list
@auth Basic username:password
@optional {If-Modified-Since: str}
@returns(200) {awards: [map]}
@errors {500}

@endpoint GET /{season}/awards/team/{teamNumber}
@auth Basic username:password
@returns(200) {Awards: [map]}
@returns(200) {code: int, message: str}

@endpoint GET /{season}/awards/eventteam/{eventCode}/{teamNumber}
@auth Basic username:password
@returns(200) {Awards: [map]}
@returns(200) {code: int, message: str}

@endpoint GET /{season}/scores/{eventCode}/{tournamentLevel}
@auth Basic username:password
@optional {If-Modified-Since: str}
@returns(200) {MatchScores: [map]}
@returns(200) {MatchScores: [map]}
@returns(200) {MatchScores: [map]}
@returns(200) {MatchScores: [map]}
@returns(200) {MatchScores: [map]}
@returns(200) {MatchScores: [map]}
@returns(200) {MatchScores: [map]}
@errors {500}

@endpoint GET /{season}/matches/{eventCode}
@auth Basic username:password
@optional {If-Modified-Since: str}
@returns(200) {Matches: [map]}
@errors {500}

@endpoint GET /{season}/rankings/district/qualPerformanceCalculation
@returns(200)

@endpoint GET /{season}/rankings/district/allianceSelectionCalculation
@returns(200)

@endpoint GET /{season}/rankings/district/playoffAdvancementCalculation
@returns(200)

@endpoint GET /{season}/rankings/{eventCode}
@auth Basic username:password
@optional {If-Modified-Since: str}
@returns(200) {Rankings: [map]}
@errors {500}

@endpoint GET /{season}/rankings/district
@auth Basic username:password
@optional {If-Modified-Since: str}
@returns(200) {districtRanks: [map], rankingCountTotal: int, rankingCountPage: int, pageCurrent: int, pageTotal: int}
@errors {500}

@endpoint GET /{season}/schedule/{eventCode}
@auth Basic username:password
@optional {If-Modified-Since: str}
@returns(200) {Schedule: [map]}
@errors {500}

@endpoint GET /{season}/alliances/{eventCode}
@auth Basic username:password

@endgroup

@end
