@lap v0.3
# Machine-readable API spec. Each @endpoint block is one API call.
@api Security Center
@base https://management.azure.com
@version 2019-01-01
@auth OAuth2
@endpoints 2
@toc {resourceId}(2)

@endpoint GET /{resourceId}/providers/Microsoft.Security/advancedThreatProtectionSettings/{settingName}
