@lap v0.3
# Machine-readable API spec. Each @endpoint block is one API call.
@api IP Geolocation API
@base https://api-bdc.net
@auth ApiKey key in query
@endpoints 3
@toc data(3)

@endpoint GET /data/ip-geolocation
@required {ip: str, localityLanguage: str, key: str}
@returns(200) {ip: str, localityLanguageRequested: str, isReachableGlobally: bool, country: map{isoAlpha2: str, isoAlpha3: str, m49Code: int, name: str, isoName: str, isoNameFull: str, isoAdminLanguages: [map], unRegion: str, currency: map{numericCode: int, code: str, name: str, minorUnits: int}, wbRegion: map{id: str, iso2Code: str, value: str}, wbIncomeLevel: map{id: str, iso2Code: str, value: str}, callingCode: str, countryFlagEmoji: str, wikidataId: str, geonameId: int}, location: map{continent: str, continentCode: str, principalSubdivision: str, isoPrincipalSubdivision: str, isoPrincipalSubdivisionCode: str, city: str, localityName: str, postcode: str, latitude: num, longitude: num, plusCode: str, timeZone: map{ianaTimeId: str, displayName: str, effectiveTimeZoneFull: str, effectiveTimeZoneShort: str, utcOffsetSeconds: int, utcOffset: str, isDaylightSavingTime: bool, localTime: str}, localityInfo: map{administrative: [map], informative: [map]}}, lastUpdated: str, network: map{registry: str, registryStatus: str, registeredCountry: str, registeredCountryName: str, organisation: str, isReachableGlobally: bool, isBogon: bool, bgpPrefix: str, bgpPrefixNetworkAddress: str, bgpPrefixLastAddress: str, totalAddresses: int, carriers: [map], viaCarriers: [map]}, confidence: str, confidenceArea: [map], securityThreat: str, hazardReport: map{isKnownAsTorServer: bool, isKnownAsVpn: bool, isKnownAsProxy: bool, isSpamhausDrop: bool, isSpamhausEdrop: bool, isSpamhausAsnDrop: bool, isBlacklistedUceprotect: bool, isBlacklistedBlocklistDe: bool, isKnownAsMailServer: bool, isKnownAsPublicRouter: bool, isBogon: bool, isUnreachable: bool, hostingLikelihood: int, isHostingAsn: bool, isCellular: bool, iCloudPrivateRelay: bool}}

