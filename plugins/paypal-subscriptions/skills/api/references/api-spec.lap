@endpoint POST /v1/billing/plans/{id}/update-pricing-schemes
@required {id: str, pricing_schemes: [map{billing_cycle_sequence!: int, pricing_scheme!: map{version: int, fixed_price: map, pricing_model: str, tiers: [map], create_time: str(ppaas_date_time_v3), update_time: str(ppaas_date_time_v3)}}]}
