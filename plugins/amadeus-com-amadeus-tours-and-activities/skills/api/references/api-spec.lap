@lap v0.3
# Machine-readable API spec. Each @endpoint block is one API call.
@api Tours and Activities
@base https://test.api.amadeus.com/v1
@version 1.0.2
@endpoints 3
@toc shopping(3)

@endpoint GET /shopping/activities
@required {latitude: any, longitude: any}
@optional {radius: any}
@returns(200)
@errors {400}

@endpoint GET /shopping/activities/by-square
@required {north: any, west: any, south: any, east: any}
@returns(200)
