@lap v0.3
# Machine-readable API spec. Each @endpoint block is one API call.
@api doqs.dev | PDF filling API
@base https://api.doqs.dev/v1
@version 1.0
@auth ApiKey x-api-key in header
@endpoints 4
@toc pdf-filling(2), pdf-generator(2)

@group pdf-filling
@endpoint POST /pdf-filling/templates/{id}/fill
@required {id: str}
@optional {data: map={}}
@returns(200)
@errors {4XX, 5XX}

@endpoint GET /pdf-filling/templates
@optional {limit: int=100, offset: int=0}
@returns(200) {results: [map]}
@errors {4XX, 5XX}

@endgroup

@group pdf-generator
@endpoint POST /pdf-generator/render
@required {template_html: str}
@optional {header_template: any, footer_template: any, pdf: any={'format': 'a4', 'orientation': 'portrait', 'scale': 1.0}, presigned_upload: any}
@returns(200)
@errors {4XX, 5XX, 408, 426}

@endpoint GET /pdf-generator/submissions
@optional {limit: int=100, offset: int=0}
@returns(200) {results: [map]}
@errors {4XX, 5XX}

@endgroup

@end
