@lap v0.3
# Machine-readable API spec. Each @endpoint block is one API call.
@api Facial Recognition Reverse Image Face Search API
@version v1.02
@auth ApiKey Authorization in header
@endpoints 4
@toc api(4)

@endpoint POST /api/upload_pic
@returns(200) {id_search: str?, message: str?, progress: int(int32)?, error: str?, code: str?, output: map{items: [map]?, tookSeconds: num(double)?, tookSecondsDownload: num(double)?, tookSecondsQueue: num(double)?, searchedFaces: int(int64)?, freeRam: num(double)?, demo: bool?, face_per_sec: int(int32)?, performance: str?, max_score: int(int32), images_in_bundle: int(int32), scaned_till_index: int(int64), type: int(int32), hasItems: bool}, input: [map]?, facemon_status: str?, facemon_last_scann: int(int64)?, was_updated: bool, hasEmptyImages: bool, new_seen_count: int(int32)}

@endpoint POST /api/delete_pic
@optional {id_search: str, id_pic: str}
@returns(200) {id_search: str?, message: str?, progress: int(int32)?, error: str?, code: str?, output: map{items: [map]?, tookSeconds: num(double)?, tookSecondsDownload: num(double)?, tookSecondsQueue: num(double)?, searchedFaces: int(int64)?, freeRam: num(double)?, demo: bool?, face_per_sec: int(int32)?, performance: str?, max_score: int(int32), images_in_bundle: int(int32), scaned_till_index: int(int64), type: int(int32), hasItems: bool}, input: [map]?, facemon_status: str?, facemon_last_scann: int(int64)?, was_updated: bool, hasEmptyImages: bool, new_seen_count: int(int32)}

@endpoint POST /api/info
@returns(200) {faces: int(int64)?, is_online: bool, remaining_credits: int(int32), has_credits_to_search: bool}

@endpoint POST /api/search
@optional {id_search: str, with_progress: bool, id_captcha: str, status_only: bool, demo: bool, shady_only: bool}
@returns(200) {id_search: str?, message: str?, progress: int(int32)?, error: str?, code: str?, output: map{items: [map]?, tookSeconds: num(double)?, tookSecondsDownload: num(double)?, tookSecondsQueue: num(double)?, searchedFaces: int(int64)?, freeRam: num(double)?, demo: bool?, face_per_sec: int(int32)?, performance: str?, max_score: int(int32), images_in_bundle: int(int32), scaned_till_index: int(int64), type: int(int32), hasItems: bool}, input: [map]?, facemon_status: str?, facemon_last_scann: int(int64)?, was_updated: bool, hasEmptyImages: bool, new_seen_count: int(int32)}

@end
