@lap v0.3
# Machine-readable API spec. Each @endpoint block is one API call.
@api WorkBC Job Posting API
@base https://workbcjobs.api.gov.bc.ca/v1
@version 1.0.0
@endpoints 5
@toc majorProjects(1), jobTypes(1), regions(1), Industries(1), jobs(1)

@group majorProjects
@endpoint GET /majorProjects
@returns(200)

@endgroup

@group jobTypes
@endpoint GET /jobTypes
@returns(200)

@endgroup

@group regions
@endpoint GET /regions
@returns(200)

@endgroup

@group Industries
@endpoint GET /Industries
@returns(200)

@endgroup

@group jobs
@endpoint POST /jobs
@optional {lastRequestDate: str=2018-08-29, region: int(1/2)=1, city: str(Victoria/Vancouver)=Victoria, jobTypes: int([1]/[2])=[1], majorProjects: bool=True}
@returns(200) {Jobs: [map]}

@endgroup

@end
